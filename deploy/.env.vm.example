# ---- Release image selection ----
OPSWATCH_GHCR_OWNER=your-github-org-or-user
OPSWATCH_IMAGE_TAG=v0.1.0

# ---- Public ingress / TLS ----
OPSWATCH_DOMAIN=opswatch.example.com
OPSWATCH_ACME_EMAIL=ops@example.com

# ---- Core runtime secrets/config ----
POSTGRES_DB=opswatch
POSTGRES_USER=opswatch
POSTGRES_PASSWORD=replace_me
DATABASE_URL=postgresql+psycopg://opswatch:replace_me@postgres:5432/opswatch
REDIS_URL=redis://redis:6379/0
OPSWATCH_AUTH_SECRET=replace_me
OPSWATCH_SESSION_TTL_HOURS=12
OPSWATCH_AUTH_COOKIE_SECURE=true
OPSWATCH_API_KEY=
SCHEDULER_POLL_SECONDS=5

# ---- Observability (localhost-bound by default) ----
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=replace_me

# ---- Backup defaults (used by deploy/scripts/*.sh) ----
BACKUP_DIR=/var/backups/opswatch
BACKUP_RETENTION_DAYS=14
