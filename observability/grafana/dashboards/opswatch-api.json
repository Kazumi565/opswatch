{
  "uid": "opswatch-api",
  "title": "OpsWatch API",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (by status)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 9 },
      "targets": [
        {
          "expr": "sum(rate(opswatch_http_requests_total[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p95 (seconds)",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 9 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(opswatch_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
