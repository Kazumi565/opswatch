# Database
POSTGRES_DB=opswatch
POSTGRES_USER=opswatch
POSTGRES_PASSWORD=change_me

# App
DATABASE_URL=postgresql+psycopg://opswatch:change_me@postgres:5432/opswatch
REDIS_URL=redis://redis:6379/0
OPSWATCH_AUTH_SECRET=dev_only_change_me
OPSWATCH_SESSION_TTL_HOURS=12
OPSWATCH_AUTH_COOKIE_SECURE=false
OPSWATCH_API_KEY=optional-admin-automation-key
# APP_VERSION / APP_COMMIT / APP_BUILT_AT are derived automatically for local make-based Compose builds.
